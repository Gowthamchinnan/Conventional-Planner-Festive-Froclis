                <asp:MenuItem NavigateUrl="~/OwnerLogin.aspx" Text="Client Login" 
                    Value="Client Login"></asp:MenuItem>
                <asp:MenuItem Text="User Login" Value="User Login" 
                    NavigateUrl="~/UserLogin.aspx"></asp:MenuItem>
            </Items>
            <StaticHoverStyle ForeColor="Red" />
            <StaticMenuItemStyle HorizontalPadding="80px" />
        </asp:Menu>
                   
                   </td>
                   </tr>
                   <tr>
                   <td>
        <asp:Menu ID="Menu2" runat="server" Orientation="Horizontal" 
            StaticEnableDefaultPopOutImage="False" Visible="False" ForeColor="#009900">
            <DynamicHoverStyle ForeColor="Red" />
            <DynamicMenuItemStyle HorizontalPadding="20px" ItemSpacing="5px" 
