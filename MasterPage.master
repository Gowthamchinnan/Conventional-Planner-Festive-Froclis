                    <asp:MenuItem NavigateUrl="~/InsertMoidsoftServiceDetails.aspx" 
                        Text="Moisoft Service Details" Value="Moisoft Service Details">
                    </asp:MenuItem>
                    <asp:MenuItem NavigateUrl="~/AdminViewMoiandMoiserviceDetails.aspx" 
                        Text="View Moisoft and Service Details" 
                        Value="View Moisoft and Service Details"></asp:MenuItem>
                </asp:MenuItem>
                <asp:MenuItem NavigateUrl="~/AdminViewHallBookingDetails.aspx" 
                    Text="View Hall Booking" Value="View Hall Booking"></asp:MenuItem>
                <asp:MenuItem Text="View User/Client" Value="View User/Client">
                    <asp:MenuItem NavigateUrl="~/AdminViewUserDetails.aspx" 
                        Text="View User Details" Value="View User Details"></asp:MenuItem>
                    <asp:MenuItem NavigateUrl="~/AdminViewOwnerDetails.aspx" 
                        Text="View Client Details" Value="View Client Details"></asp:MenuItem>
                </asp:MenuItem>
                <asp:MenuItem NavigateUrl="~/Homepage.aspx" Text="Logout" Value="Logout">
                </asp:MenuItem>
            </Items>
            <StaticHoverStyle ForeColor="Red" />
            <StaticMenuItemStyle HorizontalPadding="20px" />
        </asp:Menu>
                   
                   </td>
                   
                   </tr>
                   <tr>
                   <td>
        <asp:Menu ID="Menu3" runat="server" Orientation="Horizontal" 
