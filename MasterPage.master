                   <table >
                   <tr>
                   <td>
        <asp:Menu ID="Menu1" runat="server" Orientation="Horizontal" 
            StaticEnableDefaultPopOutImage="False" Visible="False" ForeColor="#009933">
            <DynamicMenuItemStyle HorizontalPadding="80px" />
            <Items>
                <asp:MenuItem NavigateUrl="~/Homepage.aspx" Text="Homepage" Value="Homepage">
